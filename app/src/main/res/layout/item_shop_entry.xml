<?xml version="1.0" encoding="utf-8"?>
<!-- item_shop_entry.xml -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/bg_elevated"
    app:cardCornerRadius="@dimen/corner_md"
    app:cardElevation="0dp"
    app:strokeColor="@color/border_default"
    app:strokeWidth="0.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        app:gap="12dp">

        <!-- Item icon -->
        <ImageView
            android:id="@+id/iv_shop_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_potion"
            android:tint="@color/teal_300"
            tools:ignore="ContentDescription"
            xmlns:tools="http://schemas.android.com/tools" />

        <!-- Name + description -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_shop_item_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Energy Potion"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body"
                android:fontFamily="@font/exo2_medium" />

            <TextView
                android:id="@+id/tv_shop_item_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Restores 30 energy in battle."
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_xs"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Inflated price + buy button -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            app:gap="4dp">

            <TextView
                android:id="@+id/tv_shop_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¢ 130"
                android:textColor="@color/amber_400"
                android:textSize="@dimen/text_body"
                android:fontFamily="@font/exo2_medium"
                android:gravity="center" />

            <Button
                android:id="@+id/btn_buy"
                android:layout_width="64dp"
                android:layout_height="34dp"
                android:text="Buy"
                android:textSize="@dimen/text_xs"
                style="@style/ButtonPrimary"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
