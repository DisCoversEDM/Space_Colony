<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_stats.xml -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 2 column metric grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="3">

                <!-- Missions completed -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="12dp"
                    android:layout_margin="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stats_missions_completed"
                        style="@style/TextSectionHeader" />

                    <TextView
                        android:id="@+id/tv_stat_missions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/teal_300"
                        android:textSize="@dimen/text_xl"
                        android:fontFamily="@font/exo2_medium" />
                </LinearLayout>

                <!-- Win / loss ratio -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="12dp"
                    android:layout_margin="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stats_win_loss"
                        style="@style/TextSectionHeader" />

                    <TextView
                        android:id="@+id/tv_stat_winloss"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 0"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_xl"
                        android:fontFamily="@font/exo2_medium" />
                </LinearLayout>

                <!-- Total credits earned -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="12dp"
                    android:layout_margin="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stats_credits_total"
                        style="@style/TextSectionHeader" />

                    <TextView
                        android:id="@+id/tv_stat_credits"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¢ 0"
                        android:textColor="@color/amber_400"
                        android:textSize="@dimen/text_xl"
                        android:fontFamily="@font/exo2_medium" />
                </LinearLayout>

                <!-- Highest threat defeated -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="12dp"
                    android:layout_margin="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stats_highest_threat"
                        style="@style/TextSectionHeader" />

                    <TextView
                        android:id="@+id/tv_stat_threat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level 0"
                        android:textColor="@color/coral_300"
                        android:textSize="@dimen/text_xl"
                        android:fontFamily="@font/exo2_medium" />
                </LinearLayout>

                <!-- Most used crew member (spans 2 columns) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnSpan="2"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="12dp"
                    android:layout_margin="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stats_top_crew"
                        style="@style/TextSectionHeader" />

                    <TextView
                        android:id="@+id/tv_stat_top_crew"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="None"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body"
                        android:fontFamily="@font/exo2_medium" />
                </LinearLayout>

            </GridLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_new_game"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:text="New Game"
        android:backgroundTint="@color/coral_300"
        android:textColor="#FFFFFF"
        app:cornerRadius="24dp"
        app:icon="@android:drawable/ic_menu_rotate" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
