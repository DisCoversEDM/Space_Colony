<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:id="@+id/main"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- top HUD bar -->
    <LinearLayout
        android:id="@+id/layout_hud_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_surface"
        android:elevation="4dp"
        android:layout_alignParentTop="true">

        <!-- Row 1: colony name + settings -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical">

            <View
                android:id="@+id/view_status_dot"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/bg_status_dot_green" />

            <TextView
                android:id="@+id/tv_colony_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Nova Kepler IV"
                android:textColor="@color/teal_300"
                android:textSize="@dimen/text_sm"
                android:letterSpacing="0.08"
                android:fontFamily="@font/exo2_medium" />

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_settings"
                android:tint="@color/gray_400"
                android:layout_marginStart="8dp"
                android:contentDescription="@string/hud_settings" />
        </LinearLayout>

        <!-- Row 2: turn, credits, inflation stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:divider="@drawable/divider_vertical"
            android:showDividers="middle">

            <!-- Turn counter -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Turn"
                    style="@style/TextSectionHeader" />

                <TextView
                    android:id="@+id/tv_turn_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textColor="@color/teal_300"
                    android:textSize="@dimen/text_xl"
                    android:fontFamily="@font/exo2_medium" />

                <TextView
                    android:id="@+id/tv_turn_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="of mission"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_xs" />
            </LinearLayout>

            <!-- Credits -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Credits"
                    style="@style/TextSectionHeader" />

                <TextView
                    android:id="@+id/tv_credits"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="500 ¢"
                    android:textColor="@color/amber_400"
                    android:textSize="@dimen/text_xl"
                    android:fontFamily="@font/exo2_medium" />

                <TextView
                    android:id="@+id/tv_credits_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="starting budget"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_xs" />
            </LinearLayout>

            <!-- Inflation -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inflation"
                    style="@style/TextSectionHeader" />

                <TextView
                    android:id="@+id/tv_inflation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.0×"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_xl"
                    android:fontFamily="@font/exo2_medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="price scale"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_xs" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 3: threat progress bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Next threat"
                android:textColor="@color/gray_400"
                android:textSize="@dimen/text_xs" />

            <ProgressBar
                android:id="@+id/progress_threat"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:layout_height="@dimen/threat_bar_height"
                android:layout_weight="1"
                android:progressDrawable="@drawable/progress_threat"
                android:max="5"
                android:progress="0"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tv_threat_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5 turns"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_sm"
                android:fontFamily="@font/exo2_medium"
                android:minWidth="48dp"
                android:gravity="end" />
        </LinearLayout>

        <!-- Row 4: alert banner (visibility toggled in code) -->
        <LinearLayout
            android:id="@+id/layout_alert_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="10dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/iv_alert_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_check_circle"
                android:tint="@color/teal_300"
                android:layout_marginEnd="8dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_alert_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/alert_stable_title"
                    android:textColor="@color/teal_300"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="@font/exo2_medium" />

                <TextView
                    android:id="@+id/tv_alert_body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/alert_stable_body"
                    android:textColor="@color/teal_200"
                    android:textSize="@dimen/text_xs" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Bottom navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/nav_height"
        android:layout_alignParentBottom="true"
        android:background="@color/bg_surface"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_bottom_nav"
        app:elevation="8dp" />

    <Button
        android:id="@+id/btn_next_turn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/bottom_nav"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:text="@string/btn_next_turn"
        style="@style/ButtonPrimary" />

    <!-- Fragment container -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layout_hud_top"
        android:layout_above="@id/btn_next_turn"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

</RelativeLayout>
