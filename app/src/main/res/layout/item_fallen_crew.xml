<?xml version="1.0" encoding="utf-8"?>
<!-- item_fallen_crew.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    app:gap="10dp">

    <!-- Skull indicator -->
    <ImageView
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_skull"
        android:tint="@color/red_400"
        tools:ignore="ContentDescription"
        xmlns:tools="http://schemas.android.com/tools" />

    <TextView
        android:id="@+id/tv_fallen_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Reyes"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_body"
        android:fontFamily="@font/exo2_medium" />

    <TextView
        android:id="@+id/tv_fallen_role"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Soldier"
        android:textColor="@color/teal_300"
        android:textSize="@dimen/text_xs"
        style="@style/RoleBadge" />

</LinearLayout>
