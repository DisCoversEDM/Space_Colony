<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_mission.xml
     Show every 5 turns when a threat arrives.
    Show incoming alien info and the squad builder. -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="16dp">

    <!-- Incoming threat card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        app:cardBackgroundColor="@color/red_900"
        app:cardCornerRadius="@dimen/corner_lg"
        app:cardElevation="0dp"
        app:strokeColor="@color/red_400"
        app:strokeWidth="0.5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical"
            app:gap="14dp">

            <!-- Alien icon placeholder -->
            <ImageView
                android:id="@+id/iv_alien_icon_preview"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_alien"
                android:tint="@color/coral_300"
                tools:ignore="ContentDescription"
                xmlns:tools="http://schemas.android.com/tools" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                app:gap="4dp">

                <TextView
                    android:id="@+id/tv_threat_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vortex Ravager"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_md"
                    android:fontFamily="@font/exo2_medium" />

                <TextView
                    android:id="@+id/tv_threat_level"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Threat level 3"
                    android:textColor="@color/coral_300"
                    android:textSize="@dimen/text_xs" />

                <TextView
                    android:id="@+id/tv_threat_damage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Deals 20–40 dmg / turn"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_xs" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Squad builder header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/mission_squad_title"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_md"
            android:fontFamily="@font/exo2_medium" />

        <TextView
            android:id="@+id/tv_squad_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/mission_squad_hint"
            android:textColor="@color/text_hint"
            android:textSize="@dimen/text_xs" />
    </LinearLayout>

    <!-- Selectable crew list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_squad_select"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:nestedScrollingEnabled="false" />

    <!-- Launch button -->
    <Button
        android:id="@+id/btn_launch_mission"
        android:layout_width="match_parent"
        android:layout_height="@dimen/action_button_height"
        android:layout_marginTop="14dp"
        android:text="@string/mission_launch"
        android:enabled="false"
        style="@style/ButtonDanger" />

</LinearLayout>
