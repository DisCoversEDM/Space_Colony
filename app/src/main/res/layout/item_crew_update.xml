<?xml version="1.0" encoding="utf-8"?>
<!-- item_crew_update.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="5dp"
    android:paddingBottom="5dp"
    app:gap="10dp">

    <TextView
        android:id="@+id/tv_update_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Kwan"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_body"
        android:fontFamily="@font/exo2_medium" />

    <!-- Update chip like Survived, Injured, Full HP -->
    <TextView
        android:id="@+id/tv_update_chip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Survived"
        android:textColor="@color/teal_300"
        android:textSize="@dimen/text_xs"
        android:background="@drawable/bg_role_badge"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp" />

</LinearLayout>
