<?xml version="1.0" encoding="utf-8"?>
<!-- item_crew_card.xml
     Single crew member card used in the Crew Roster RecyclerView. -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="@dimen/corner_lg"
    app:cardElevation="0dp"
    app:strokeColor="@color/border_default"
    app:strokeWidth="0.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/card_padding">

        <!-- Row 1: name + role badge + xp + status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:gap="8dp">

            <TextView
                android:id="@+id/tv_crew_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reyes"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_md"
                android:fontFamily="@font/exo2_medium"
                android:singleLine="true"
                android:ellipsize="end" />

            <!-- Role badge - tint set in code based on role -->
            <TextView
                android:id="@+id/tv_crew_role"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Soldier"
                style="@style/RoleBadge"
                android:textColor="@color/teal_300" />

            <TextView
                android:id="@+id/tv_crew_xp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/crew_xp_format"
                android:textColor="@color/amber_300"
                android:textSize="@dimen/text_xs"
                android:fontFamily="@font/exo2_medium"
                android:layout_marginStart="4dp" />

            <!-- Status chip -->
            <TextView
                android:id="@+id/tv_crew_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quarters"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_xs"
                android:background="@drawable/bg_role_badge"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- Row 2: HP bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp"
            app:gap="8dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:text="HP"
                android:textColor="@color/bar_hp"
                android:textSize="@dimen/text_xs"
                android:fontFamily="@font/exo2_medium" />

            <ProgressBar
                android:id="@+id/progress_crew_hp"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:layout_height="@dimen/stat_bar_height"
                android:layout_weight="1"
                android:progressDrawable="@drawable/progress_hp"
                android:max="100"
                android:progress="90" />

            <TextView
                android:id="@+id/tv_crew_hp_value"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="90/100"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_xs"
                android:gravity="end" />
        </LinearLayout>

        <!-- Row 3: Energy bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="5dp"
            app:gap="8dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:text="EN"
                android:textColor="@color/bar_energy"
                android:textSize="@dimen/text_xs"
                android:fontFamily="@font/exo2_medium" />

            <ProgressBar
                android:id="@+id/progress_crew_energy"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:layout_height="@dimen/stat_bar_height"
                android:layout_weight="1"
                android:progressDrawable="@drawable/progress_energy"
                android:max="100"
                android:progress="70" />

            <TextView
                android:id="@+id/tv_crew_energy_value"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="70/100"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_xs"
                android:gravity="end" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
