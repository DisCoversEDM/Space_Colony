<?xml version="1.0" encoding="utf-8"?>
<!-- activity_battle.xml
     battle layout.
     Top: alien section
     Middle: squad row
     Bottom: 2x2 action grid -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_battle_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!--Alien section -->
    <LinearLayout
        android:id="@+id/layout_alien"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/bg_surface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:gap="14dp">

            <!-- Alien icon (flashes on crit) -->
            <ImageView
                android:id="@+id/iv_alien_battle"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_alien"
                android:tint="@color/coral_400"
                tools:ignore="ContentDescription"
                xmlns:tools="http://schemas.android.com/tools" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                app:gap="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_alien_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Vortex Ravager"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_md"
                        android:fontFamily="@font/exo2_medium" />

                    <TextView
                        android:id="@+id/tv_alien_threat_level"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Threat 3"
                        android:textColor="@color/coral_300"
                        android:textSize="@dimen/text_xs"
                        android:background="@drawable/bg_alert_danger"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp" />
                </LinearLayout>

                <!-- Alien HP bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    app:gap="8dp">

                    <TextView
                        android:layout_width="20dp"
                        android:layout_height="wrap_content"
                        android:text="HP"
                        android:textColor="@color/bar_hp"
                        android:textSize="@dimen/text_xs"
                        android:fontFamily="@font/exo2_medium" />

                    <ProgressBar
                        android:id="@+id/progress_alien_hp"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/battle_hp_bar_height"
                        android:layout_weight="1"
                        android:progressDrawable="@drawable/progress_hp"
                        android:max="100"
                        android:progress="100" />

                    <TextView
                        android:id="@+id/tv_alien_hp"
                        android:layout_width="52dp"
                        android:layout_height="wrap_content"
                        android:text="200 / 200"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_xs"
                        android:gravity="end" />
                </LinearLayout>

                <!-- Crit chance indicator -->
                <TextView
                    android:id="@+id/tv_alien_crit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Crit chance: 20%"
                    android:textColor="@color/amber_400"
                    android:textSize="@dimen/text_xs" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Squad row-->
    <LinearLayout
        android:id="@+id/layout_squad_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:gravity="center"
        app:gap="8dp"
        app:layout_constraintTop_toBottomOf="@id/layout_alien"
        app:layout_constraintBottom_toTopOf="@id/layout_action_grid"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Bomboclatt wallahi crews here
        (will be inflated using item_crew_card if filled or not idk) -->
        <include layout="@layout/item_crew_battle_card" />

    </LinearLayout>

    <!-- 2×2 Action grid -->
    <GridLayout
        android:id="@+id/layout_action_grid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:padding="12dp"
        app:gap="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Attack -->
        <Button
            android:id="@+id/btn_action_attack"
            android:layout_width="0dp"
            android:layout_height="@dimen/action_button_height"
            android:layout_columnWeight="1"
            android:text="@string/battle_action_attack"
            android:textSize="@dimen/text_body"
            style="@style/ButtonDanger" />

        <!-- Rest -->
        <Button
            android:id="@+id/btn_action_rest"
            android:layout_width="0dp"
            android:layout_height="@dimen/action_button_height"
            android:layout_columnWeight="1"
            android:text="@string/battle_action_rest"
            android:textSize="@dimen/text_body"
            style="@style/ButtonSecondary" />

        <!-- Use Potion -->
        <Button
            android:id="@+id/btn_action_potion"
            android:layout_width="0dp"
            android:layout_height="@dimen/action_button_height"
            android:layout_columnWeight="1"
            android:text="@string/battle_action_potion"
            android:textSize="@dimen/text_body"
            style="@style/ButtonSecondary"
            android:enabled="false" />

        <!-- Use First Aid -->
        <Button
            android:id="@+id/btn_action_first_aid"
            android:layout_width="0dp"
            android:layout_height="@dimen/action_button_height"
            android:layout_columnWeight="1"
            android:text="@string/battle_action_first_aid"
            android:textSize="@dimen/text_body"
            style="@style/ButtonSecondary"
            android:enabled="false" />

    </GridLayout>

    <!-- Crit flash overlay (alpha animated in code on critical hit) -->
    <View
        android:id="@+id/view_crit_flash"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/coral_400"
        android:alpha="0"
        android:clickable="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
