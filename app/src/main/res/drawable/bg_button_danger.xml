<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/coral_300" />
            <corners android:radius="@dimen/corner_md" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape>
            <solid android:color="@color/bg_elevated" />
            <corners android:radius="@dimen/corner_md" />
            <stroke android:width="0.5dp" android:color="@color/border_default" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/coral_400" />
            <corners android:radius="@dimen/corner_md" />
        </shape>
    </item>
</selector>
