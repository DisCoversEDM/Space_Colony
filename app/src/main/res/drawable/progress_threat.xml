<?xml version="1.0" encoding="utf-8"?>
<!-- progress_threat.xml
     The fill color is swapped throuygh setProgressTintList()
     based on turns remaining:
       3+ turns  -> teal_400
       2 turns   -> amber_400
       1 turn    -> red_400
       0 turns   -> red_400 (pulsing animator applied in code)
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <solid android:color="@color/bar_track" />
            <corners android:radius="@dimen/corner_pill" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <solid android:color="@color/teal_400" />
                <corners android:radius="@dimen/corner_pill" />
            </shape>
        </clip>
    </item>
</layer-list>
